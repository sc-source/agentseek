{% set item_description = item.get("description_" ~ ui.locale, item.description) %}
        <article class="hub-card" data-search="{{ [category.name, ui.category_labels.get(category.name, category.name), item.name, item.description, item_description, item.install | default(''), item.create | default(''), (item.tags | default([]) | join(' '))] | join(' ') | lower }}">
          <div class="hub-card-header">
{% if item.repo_url %}
            <a class="hub-card-name" href="{{ item.repo_url }}">{{ item.name }}</a>
{% elif item.skill_url %}
            <a class="hub-card-name" href="{{ item.skill_url }}">{{ item.name }}</a>
{% else %}
            <span class="hub-card-name">{{ item.name }}</span>
{% endif %}
{% for badge in item.badges | default([]) %}
            <span class="hub-badge{% if badge.class %} {{ badge.class }}{% endif %}">{{ ui.badge_labels.get(badge.label, badge.label) }}</span>
{% endfor %}
          </div>
          <p class="hub-card-desc">{{ item_description }}</p>
{% if item.entry_point %}
          <p class="hub-card-meta">{{ ui.entry_point_label }}: <code>{{ item.entry_point }}</code></p>
{% elif item.path %}
          <p class="hub-card-meta">{{ ui.path_label }}: <code>{{ item.path }}</code></p>
{% endif %}
{% set has_bundled_badge = (item.badges | default([]) | selectattr('label', 'equalto', 'bundled') | list | length) > 0 %}
{% if item.install and not has_bundled_badge %}
          <div class="hub-install">
            <div class="hub-install-cmd" tabindex="0" role="group" aria-label="{{ ui.install_command_label }}">
              <code>{{ item.install }}</code>
            </div>
            <button type="button" class="hub-copy-btn" data-copy-cmd="{{ item.install }}" data-copy-label="{{ ui.copy_label }}" data-copied-label="{{ ui.copied_label }}">{{ ui.copy_label }}</button>
          </div>
{% endif %}
{% if item.create %}
          <div class="hub-install">
            <div class="hub-install-cmd" tabindex="0" role="group" aria-label="{{ ui.create_command_label }}">
              <code>{{ item.create }}</code>
            </div>
            <button type="button" class="hub-copy-btn" data-copy-cmd="{{ item.create }}" data-copy-label="{{ ui.copy_label }}" data-copied-label="{{ ui.copied_label }}">{{ ui.copy_label }}</button>
          </div>
{% endif %}
{% if item.readme_url or item.skill_url %}
          <div class="hub-links">
{% if item.readme_url %}
            <a href="{{ item.readme_url }}">{{ ui.readme_label }}</a>
{% endif %}
{% if item.skill_url %}
            <a href="{{ item.skill_url }}">{{ ui.skill_doc_label }}</a>
{% endif %}
          </div>
{% endif %}
        </article>
